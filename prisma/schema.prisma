generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url = env("DATABASE_URL")
}

model Categoria {
  id        String     @id @default(cuid())

  nome      String
  icone     String
  cor       String
  
  produtos  Produto[]

  criadoEm  DateTime @default(now())
}

model Produto {
  id                 String @id @default(cuid())
  nome               String

  quantidade         Int
  quantidadeMinima   Int

  preco              Float
  unidade            String

  foto               String?

  categoriaId        String
  categoria          Categoria @relation(fields: [categoriaId], references: [id])

  movimentacoes      Movimentacao[]

  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt
}

model Usuario {
  id          String @id @default(cuid())

  nome        String
  email       String @unique
  senha       String
  refreshToken String?
  criadoEm    DateTime @default(now())
}

model Movimentacao {
  id            String @id @default(cuid())

  tipo          String
  quantidade    Int
  observacao    String?

  produtoId     String
  produto       Produto @relation(fields: [produtoId], references: [id])

  criadoEm      DateTime @default(now())
}

